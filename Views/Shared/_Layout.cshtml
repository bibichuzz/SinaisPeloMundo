<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sinais Pelo Mundo</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SinaisPeloMundo.styles.css" asp-append-version="true" />
<link rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
</head>
    <body>
    <header class="home-header">
        <div class="home-container home-header-wrapper">
            <button class="home-header-menu-toggle" id="tiMenuToggle" aria-label="Abrir menu">
                <span></span>
                <span></span>
                <span></span>
            </button>

            <div class="home-header-logo">
                <img src="https://i.imgur.com/4qTquOz.jpeg" alt="Logo">
            </div>

            @{
                var clienteLogado = Context.Session.GetString("sessaoClienteLogado");
            }

            @if (string.IsNullOrEmpty(clienteLogado))
            {
                <a asp-controller="Cliente"
                   asp-action="Cadastro"
                   class="home-header-login">

                    <span class="material-symbols-outlined">account_circle</span>
                    <span>Entrar</span>

                </a>
            }
            else
            {
                <a asp-controller="Cliente"
                   asp-action="DadosPessoais"
                   class="home-header-login">

                    <span class="material-symbols-outlined">account_circle</span>
                    <span>Minha Conta</span>

                </a>
            }

            <nav class="home-header-navbar" id="tiNavbar">
                <ul class="home-header-nav-list">
                    <li><a asp-controller="Home" asp-action="Index" class="home-header-nav-link">Início</a></li>
                    <li><a asp-controller="Home" asp-action="Catalogo" class="home-header-nav-link">Catálogo</a></li>
                </ul>
            </nav>
        </div>
    </header>
    @RenderBody()
    <footer class="home-footer">
        <div class="home-container home-footer-wrapper">
            <section>
                <div class="home-footer-logo">
                    <img src="https://i.imgur.com/4qTquOz.jpeg" alt="Logo">
                </div>
                <p class="home-footer-text" style="margin-top: 1rem;">
                    Turismo acessível e inclusivo para você viver o melhor do mundo com tranquilidade.
                </p>
            </section>

            <nav>
                <h4 class="home-footer-column-title">Navegação</h4>
                <ul class="home-footer-list">
                    <li class="home-footer-item"><a asp-controller="Home" asp-action="Index">Início</a></li>
                    <li class="home-footer-item"><a asp-controller="Home" asp-action="Catalogo">Pacotes</a></li>
                </ul>
            </nav>

            <section>
                <h4 class="home-footer-column-title">Contato</h4>
                <ul class="home-footer-list">
                    <li class="home-footer-item">sinaispelomundo@gmail.com</li>
                    <li class="home-footer-item">(11) 99999-9999</li>
                </ul>
            </section>
        </div>

        <div class="home-footer-copyright">
            © 2026 Sinais pelo Mundo. Todos os direitos reservados.
        </div>
    </footer>
    <script>
        // Seleciona o botão hambúrguer pelo ID
        const tiMenuToggle = document.getElementById("tiMenuToggle");
        // Seleciona a Sidebar (que agora tem o ID tiNavbar)
        const tiNavbar = document.getElementById("tiNavbar");

        // Adiciona o evento de clique
        tiMenuToggle.addEventListener("click", () => {
            // Liga/Desliga a classe que define a altura máxima (max-height)
            tiNavbar.classList.toggle("home-navbar-active");
        });
            </script>

    <div vw class="enabled">
        <div vw-access-button class="active"></div>
        <div vw-plugin-wrapper>
            <div class="vw-plugin-top-wrapper"></div>
        </div>
    </div>

    <script src="https://vlibras.gov.br/app/vlibras-plugin.js"></script>

    <script>
        new window.VLibras.Widget('https://vlibras.gov.br/app');
    </script>
    </body>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</html>
